{
  "name": "backend-project",
  "version": "1.0.0",
  "description": "Basic backend application",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "typecheck": "tsc --noEmit",
    "dev": "tsc && node dist/app.js",
    "start-server": "npx tsc && node dist/app.js",
    "watch": "tsc --watch",
    "migration:run": "npm run build && npx typeorm migration:run -d dist/src/db/data-source.js",
    "swagger:gen": "node --loader ts-node/esm scripts/swagger-gen.ts",
    "postman:gen": "npm run build && node dist/scripts/postman-gen.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.17.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "typeorm-naming-strategies": "^4.1.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.9",
    "@types/pg": "^8.16.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^3.0.1",
    "openapi-to-postmanv2": "^6.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
